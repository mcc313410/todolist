<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.TodoList" parent="Theme.MaterialComponents.Light.NoActionBar">
        <!-- 主色 雾蓝高级调 -->
        <item name="colorPrimary">@color/brand_primary</item>
        <item name="colorPrimaryVariant">#3B82F6</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <!-- 辅助暖黄 用于收藏、强调 -->
        <item name="colorSecondary">@color/brand_secondary</item>
        <item name="colorSecondaryVariant">#F59E0B</item>
        <item name="colorOnSecondary">#1E293B</item>
        <!-- 全局页面、卡片底色 -->
        <item name="android:colorBackground">@color/bg_page</item>
        <item name="colorSurface">@color/bg_card</item>
        <item name="colorOnSurface">@color/text_main</item>
        <!-- 状态色绑定 -->
        <item name="colorError">@color/state_danger</item>
        <item name="colorOnError">#FFFFFF</item>
        <!-- 状态栏 深色文字适配浅主色 -->
        <item name="android:statusBarColor">@color/brand_primary</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <!-- 轻奢卡片：大圆角、弱阴影、无生硬边界 -->
    <style name="CardPremium" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">20dp</item>
        <item name="cardElevation">2dp</item>
        <item name="cardBackgroundColor">@color/bg_card</item>
        <item name="cardUseCompatPadding">true</item>
    </style>

    <!-- 简约描边按钮 -->
    <style name="ButtonOutlinedPremium" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="cornerRadius">14dp</item>
        <item name="strokeColor">@color/brand_primary</item>
        <item name="strokeWidth">1dp</item>
    </style>
</resources>