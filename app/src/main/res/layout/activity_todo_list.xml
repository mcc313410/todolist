<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7F9FF">

    <LinearLayout
        android:id="@+id/title_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="36dp"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="我的待办"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"/>

            <!-- 修复点：给 LinearLayout 加上垂直方向约束 -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">

                <TextView
                    android:id="@+id/tvArchive"
                    android:layout_width="wrap_content"
                    android:layout_height="42dp"
                    android:text="归档列表"
                    android:textSize="15sp"
                    android:textColor="#425AFE"
                    android:background="@drawable/bg_round_blue_stroke"
                    android:paddingHorizontal="14dp"
                    android:gravity="center"/>
            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="18dp"
            app:cardCornerRadius="25dp"
            app:cardElevation="1dp"
            app:cardBackgroundColor="#FFFFFF">

            <EditText
                android:id="@+id/etSearch"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@null"
                android:hint="搜索待办..."
                android:paddingHorizontal="20dp"
                android:textSize="14sp"
                android:drawableLeft="@android:drawable/ic_menu_search"
                android:drawablePadding="12dp"/>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

    <!-- 待办列表 RecyclerView 对应代码里 rv_todo_list -->

    <!-- 空数据布局 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_todo_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:paddingHorizontal="20dp"
        app:layout_constraintBottom_toTopOf="@id/btnAdd"
        app:layout_constraintTop_toBottomOf="@id/title_bar"
        app:layout_constraintVertical_bias="1.0"
        tools:layout_editor_absoluteX="-16dp"
        tools:listitem="@layout/item_todo_list" />

    <LinearLayout
        android:id="@+id/emptyLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/title_bar"
        app:layout_constraintBottom_toTopOf="@id/btnAdd">

        <ImageView
            android:layout_width="130dp"
            android:layout_height="130dp"
            android:src="@android:drawable/ic_menu_agenda"
            android:alpha="0.25"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="暂无待办，点击右下角添加吧～"
            android:textSize="15sp"
            android:textColor="#999999"
            android:layout_marginTop="16dp"/>

    </LinearLayout>

    <!-- 新增悬浮按钮 对应代码 addTodoClick 方法 -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/btnAdd"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:src="@android:drawable/ic_menu_add"
        app:tint="#FFFFFF"
        android:backgroundTint="#425AFE"
        android:layout_margin="22dp"
        android:onClick="addTodoClick"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>